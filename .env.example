# ─── Обовʼязкові ─────────────────────────────────────────────────
EMAIL_USER=your@email.com
EMAIL_PASSWORD=your_imap_password
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=123456789

# ─── IMAP (опційно) ──────────────────────────────────────────────
IMAP_HOST=imap.ukr.net
IMAP_PORT=993

# ─── Розклад тихого режиму (година початку, година кінця, 0–23) ───
# Тихий режим: QUIET_START–QUIET_END (напр. 23–7 = ніч)
QUIET_START=23
QUIET_END=7

# ─── Сервер ─────────────────────────────────────────────────────
PORT=3000
RECONNECT_DELAY=5000

# ─── Render.com ──────────────────────────────────────────────────
RENDER_EXTERNAL_URL=https://your-app.onrender.com

# ─── Безпека ─────────────────────────────────────────────────────
# Шифрування паролів у store.json (32 байти hex: openssl rand -hex 32)
# ENCRYPTION_KEY=abc123...
# API ключ для захисту /api/* ендпоінтів
# Рекомендовано: Authorization: Bearer <key> заголовок
# Також підтримується: X-API-Key заголовок або ?api_key=... параметр
# API_KEY=secret123

# ─── TLS (для самопідписаних сертифікатів IMAP) ─────────────────
# TLS_REJECT_UNAUTHORIZED=false

# ─── IMAP перепідключення ────────────────────────────────────────
# IMAP_MAX_RECONNECT_ATTEMPTS=10

# ─── Логування ───────────────────────────────────────────────────
# LOG_LEVEL=info
